(global real g_scarab_interpolation 0)

(script static void scarab_walk_front_var01
	(device_set_position_track s1 combat:walk_front:var0 g_scarab_interpolation)
	(device_animate_position s1 1.0 4 0 0 true)
	(sleep_until (>= (device_get_position s1) 1.0) 1)
)

(script dormant scarab_walk
	(object_create s1)
	(scarab_walk_front_var01)
	(scarab_walk_front_var01)
	(scarab_walk_front_var01)
	(object_destroy s1)
)

(script dormant skull_emoji
	(sleep 160)
	(object_create sc1)
	(wake scarab_walk)
	(weapon_hold_trigger sc1 0 true)
	(sleep 90)
	(weapon_hold_trigger sc1 0 false)
)

(script command_script mario
	(cs_go_to brothas/m0)
	(cs_go_to brothas/m1)
	(cs_face_object true (ai_get_object brothas/luigi))
	(sleep 120)
	(cs_face true brothas/mario_face0)
	(sleep 20)
	(cs_custom_animation objects\characters\elite\elite combat:pistol:warn 1 true)
	(sleep 45)
	(object_destroy switch)
	(object_create_anew switch_bowser)
	(cs_go_to brothas/m2)
	(object_create bu1)
	(object_create bu2)
	(object_create bu3)
	(object_create bu4)
	(object_create bu5)
